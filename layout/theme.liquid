    <meta name="google-site-verification" content="uGRCu7kyGocD4JkLrp3VChPlYzBa2aWHDehDDERVt74" />
    <script src="{{ 'pandectes-rules.js' | file_url }}"></script>
    <meta charset="utf-8">
    <meta
      name="viewport"
      <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">



    <meta name="theme-color" content="{{ settings.header_background }}">
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=AW-17495243623">
