{% schema %}
{
  "name": "Logo Grid Sectie",
  "settings": [
    {
      "type": "text",
      "id": "heading_text",
      "label": "Koptekst",
      "default": "AS SEEN ON"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Bovenste padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Onderste padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Logo Afbeelding"
        },
        {
          "type": "checkbox",
          "id": "hide_on_mobile",
          "label": "Verberg op apparaten onder 767px"
        }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Logo Grid Sectie",
      "category": "Custom"
    }
  ]
}
{% endschema %}

<div class="logo-grid-section" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
  <div class="logo-grid-container">
    <div class="logo-grid-content">
      <div class="logo-grid-heading">
        <p>{{ section.settings.heading_text }}</p>
      </div>
      <div class="logo-grid-logos">
        {% for block in section.blocks %}
          {% if block.type == 'logo' %}
            <div class="logo-grid-item{% if block.settings.hide_on_mobile %} hide-on-mobile{% endif %}">
              {% if block.settings.logo_image != blank %}
                <img src="{{ block.settings.logo_image | img_url: 'master' }}" alt="Logo">
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<style>
.logo-grid-section {
  padding-left: 16px;
  padding-right: 16px;
  max-width: 1400px;
  margin: 0 auto;
}

.logo-grid-content {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
}

.logo-grid-heading {
  font-size: 15px;
  text-align: center;
  margin-right: 20px;
}

.logo-grid-logos {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
}

.logo-grid-item {
  margin: 0 10px;
}

.logo-grid-item img {
  max-height: 22px;
}

@media (max-width: 767px) {
  .logo-grid-content {
    flex-direction: column;
  }
  .logo-grid-heading {
    margin-bottom: 12px;
    margin-right: 0;
  }
  .logo-grid-logos {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
  }
  .logo-grid-item {
    width: 25%;
    box-sizing: border-box;
    margin: 0;
    padding: 5px;
  }
  .logo-grid-item img {
    display: block;
    margin: 0 auto;
  }
  .hide-on-mobile {
    display: none;
  }
}
</style>
