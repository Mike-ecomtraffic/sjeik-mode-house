{% comment %}
  Reviews Slider Section
  Clean, minimal review cards with green stars, italic text, and dot pagination.
  Each review is a customizer block — easy to add, edit, and reorder.
{% endcomment %}

<!-- SwiperJS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.css">

<style>
  .reviews-section {
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    background-color: {{ section.settings.background_color }};
    overflow: hidden;
  }

  @media (max-width: 767px) {
    .reviews-section {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }

  .reviews-section__header {
    text-align: {{ section.settings.header_alignment }};
    max-width: 1200px;
    margin: 0 auto 32px;
    padding: 0 32px;
  }

  .reviews-section__title {
    font-family: var(--heading-font-family);
    font-size: 28px;
    font-weight: 600;
    margin: 0 0 8px;
    color: {{ section.settings.heading_color }};
  }

  .reviews-section__subtitle {
    font-size: 15px;
    color: rgba(0, 0, 0, 0.55);
    margin: 0;
  }

  @media (min-width: 768px) {
    .reviews-section__title {
      font-size: 32px;
    }
  }

  /* Swiper container */
  .reviews-section__slider {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
    position: relative;
  }

  .reviews-section__slider .swiper {
    overflow: visible;
    padding-bottom: 48px;
  }

  /* Review card */
  .review-card {
    background: #fff;
    border-radius: 12px;
    padding: 28px 24px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06), 0 2px 12px rgba(0, 0, 0, 0.04);
    display: flex;
    flex-direction: column;
    gap: 16px;
    height: 100%;
    transition: box-shadow 0.25s ease;
  }

  .review-card:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08), 0 4px 20px rgba(0, 0, 0, 0.06);
  }

  /* Stars */
  .review-card__stars {
    display: flex;
    gap: 2px;
  }

  .review-card__star {
    width: 18px;
    height: 18px;
    color: {{ section.settings.star_color }};
  }

  /* Review text */
  .review-card__text {
    font-size: 14px;
    line-height: 1.65;
    color: #333;
    font-style: italic;
    flex: 1;
    margin: 0;
  }

  /* Reviewer info */
  .review-card__author {
    margin-top: auto;
  }

  .review-card__name {
    font-size: 14px;
    font-weight: 700;
    color: #000;
    margin: 0;
  }

  .review-card__location {
    font-size: 13px;
    color: rgba(0, 0, 0, 0.5);
    margin: 2px 0 0;
  }

  /* Pagination dots */
  .reviews-section__slider .swiper-pagination {
    bottom: 0 !important;
    position: absolute;
  }

  .reviews-section__slider .swiper-pagination-bullet {
    width: 10px;
    height: 10px;
    background: #ccc;
    opacity: 1;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .reviews-section__slider .swiper-pagination-bullet-active {
    background: #000;
    transform: scale(1.15);
  }

  /* Mobile tweaks */
  @media (max-width: 767px) {
    .reviews-section__slider {
      padding: 0 16px;
    }

    .reviews-section__header {
      padding: 0 16px;
      margin-bottom: 24px;
    }

    .review-card {
      padding: 24px 20px;
    }

    .review-card__text {
      font-size: 13px;
    }
  }
</style>

<div class="reviews-section">
  {% if section.settings.heading != blank or section.settings.subheading != blank %}
    <div class="reviews-section__header">
      {% if section.settings.heading != blank %}
        <h2 class="reviews-section__title">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="reviews-section__subtitle">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="reviews-section__slider">
    <div class="swiper reviews-swiper-instance">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          {% if block.type == 'review' %}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              <div class="review-card">
                <!-- Stars -->
                <div class="review-card__stars">
                  {% assign star_count = block.settings.stars | default: 5 %}
                  {% for i in (1..star_count) %}
                    <svg class="review-card__star" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                      <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                    </svg>
                  {% endfor %}
                </div>

                <!-- Review text -->
                {% if block.settings.review_text != blank %}
                  <p class="review-card__text">{{ block.settings.review_text }}</p>
                {% endif %}

                <!-- Author -->
                <div class="review-card__author">
                  {% if block.settings.reviewer_name != blank %}
                    <p class="review-card__name">{{ block.settings.reviewer_name }}</p>
                  {% endif %}
                  {% if block.settings.reviewer_location != blank %}
                    <p class="review-card__location">{{ block.settings.reviewer_location }}</p>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
      <div class="swiper-pagination"></div>
    </div>
  </div>
</div>

<!-- SwiperJS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('.reviews-swiper-instance', {
      slidesPerView: 1.15,
      spaceBetween: 16,
      centeredSlides: true,
      grabCursor: true,
      loop: false,
      pagination: {
        el: '.reviews-section__slider .swiper-pagination',
        clickable: true
      },
      breakpoints: {
        480: {
          slidesPerView: 1.3,
          spaceBetween: 16
        },
        768: {
          slidesPerView: 2.2,
          spaceBetween: 20,
          centeredSlides: false
        },
        1024: {
          slidesPerView: 3,
          spaceBetween: 24,
          centeredSlides: true
        }
      }
    });
  });
</script>

{% schema %}
{
  "name": "Reviews Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our customers speak for themselves."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f7f7f7"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star Color",
      "default": "#00a341"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Header Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding Top (Desktop)",
      "default": 48,
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding Bottom (Desktop)",
      "default": 48,
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding Top (Mobile)",
      "default": 32,
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "default": 32,
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "label": "Star Rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "You can tell this brand pays attention to detail. The stitching, the fabric, the overall structure — it just feels well-made. I've gotten compliments at work and even from strangers. That doesn't happen often."
        },
        {
          "type": "text",
          "id": "reviewer_name",
          "label": "Reviewer Name",
          "default": "David S."
        },
        {
          "type": "text",
          "id": "reviewer_location",
          "label": "Location",
          "default": "Denver"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reviews Slider",
      "category": "Custom",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "review_text": "I've ordered multiple pieces from Harper & Wells now, and every time the quality exceeds expectations. The fit is clean, the materials feel premium, and everything looks more expensive than it is. It's become my go-to brand.",
            "reviewer_name": "Robert K.",
            "reviewer_location": "Boston"
          }
        },
        {
          "type": "review",
          "settings": {
            "review_text": "You can tell this brand pays attention to detail. The stitching, the fabric, the overall structure — it just feels well-made. I've gotten compliments at work and even from strangers. That doesn't happen often.",
            "reviewer_name": "David S.",
            "reviewer_location": "Denver"
          }
        },
        {
          "type": "review",
          "settings": {
            "review_text": "What I like most is the balance. It's modern without being flashy. Refined without trying too hard. Harper & Wells has that effortless, confident look that works anywhere.",
            "reviewer_name": "Mark L.",
            "reviewer_location": "Charlotte"
          }
        },
        {
          "type": "review",
          "settings": {
            "review_text": "Finally found a brand that gets menswear right. The pants fit perfectly, the shirts are tailored just enough, and the fabric quality is genuinely impressive for the price.",
            "reviewer_name": "James T.",
            "reviewer_location": "Austin"
          }
        }
      ]
    }
  ]
}
{% endschema %}
