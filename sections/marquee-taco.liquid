{% schema %}
{
  "name": "Marquee",
  "class": "shopify-section--marquee",
  "tag": "section",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#2A555A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFF"
    }
  ],
  "blocks": [
    {
      "type": "block",
      "name": "Block",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "DRESS WITH STYLE"
        },
        {
          "type": "checkbox",
          "id": "checkbox",
          "label": "Show the bullet?",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee",
      "blocks": [
        {
          "type": "block",
          "settings": {
            "text": "Block"
          }
        }
      ]
    }
  ]
}
{% endschema %}
