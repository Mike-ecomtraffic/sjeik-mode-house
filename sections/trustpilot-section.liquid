<style>
  .taco-trustpilot-section {
    color: #000000;
    /* Padding is now handled via inline styles */
  }

  /* Removed fixed padding from the class */
  /*
  .taco-trustpilot-section-padding {
    padding-top: 27px;
    padding-bottom: 27px;
  }

  @media screen and (min-width: 750px) {
    .taco-trustpilot-section-padding {
      padding-top: 36px;
      padding-bottom: 36px;
    }
  }
  */

  #splide01-track {
    padding-bottom: 2px;
  }

  .taco-trustpilot-section .custom__trustpilot-slider {
    display: flex;
    align-items: center;
  }

  .taco-trustpilot-section .trust_pilot--topbar {
    width: 20%;
    text-align: center;
    padding: 10px 0;
    display: none;
  }

  .taco-trustpilot-section .trust_pilot--main-area {
    width: 80%;
    padding: 0 24px;
  }

  .taco-trustpilot-section .slider__inner {
    background-color: #ffffff;
    border-radius: 10px;
    box-shadow: 0px 6px 14px -2px rgb(0 0 0 / 16%);
  }

  #splide01 {
    padding: 0px 32px;
  }

  .taco-trustpilot-section .tp_review_text {
    line-height: 1;
    font-size: 12px;
    letter-spacing: 0;
    margin: 5px 0;
  }

  .taco-trustpilot-section .review__header {
    display: flex;
    gap: 6px;
    align-items: center;
  }

  .review__icons svg {
    height: 18px;
  }

  .checkmark {
    height: 16px;
    width: 16px;
  }

  h2.trust_pilot--heading {
    font-size: 27px;
  }

  .taco-trustpilot-section .review_title {
    margin: 10px 0;
    font-size: 18px;
    font-weight: 600;
    letter-spacing: .01em;
    display: flex;
  }

  .taco-trustpilot-section .review_text {
    margin-bottom: 6px;
    font-size: 13px !important;
    letter-spacing: 0px;
    line-height: 19.5px;
    display: flex;
    margin-top: 0px;
  }

  .crispy-tp-page-width {
    max-width: {{ section.settings.trustpilot_max_width }}px !important;
  }

  .authors {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 5px;
  }

  .taco-trustpilot-section .review_author {
    margin: 0;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0px;
  }

  .taco-trustpilot-section .review__date {
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0px;
  }

  button.splide__arrow {
    background-color: #ffffff;
    opacity: 1;
    border-radius: 0px;
  }

  .splide__arrow--prev {
    left: 0em;
  }

  .splide__arrow--next {
    right: 0em;
  }

  button.splide__arrow[disabled] {
    cursor: default !important;
    opacity: .2 !important;
  }

  .trust_pilot--main-area:hover button.splide__arrow {
    opacity: 1;
  }

  .trust_pilot--main-area:hover button.splide__arrow[disabled] {
    opacity: 0.6 !important;
  }

  .trustpilot-stars {
    width: 100px;
  }

  @media screen and (max-width: 749px) {
    .taco-trustpilot-section .custom__trustpilot-slider {
      display: block;
    }

    h2.trust_pilot--heading {
      font-size: 27px;
    }

    .taco-trustpilot-section .trust_pilot--topbar {
      width: 100%;
      text-align: center;
      padding: 10px 0;
      display: none;
    }

    .taco-trustpilot-section .trust_pilot--main-area {
      width: 100%;
    }

    .taco-trustpilot-section .slider__inner {
      background-color: #ffffff;
    }

    .checkmark {
      height: 14px;
      width: 14px;
    }
  }

  .crispy-tp-page-width {
    margin: 0 auto;
    max-width: var(--container-max-width);
  }

  @media only screen and (min-width: 590px) {
    .crispy-tp-page-width {
      padding: 0 40px;
    }
  }
</style>

