<script src="https://unpkg.com/@splidejs/splide@3.0.6/dist/js/splide.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Splide('.taco-trustpilot-section .splide', {
      loop: false,
      perPage: {{ section.settings.slides_desktop }},
      perMove: 1,
      arrows: true,
      pagination: false,
      autoplay: false,
      breakpoints: {
        749: {
          perPage: {{ section.settings.slides_mobile }},
        },
        480: {
          perPage: {{ section.settings.slides_mobile }},
          focus: 'center',
        },
      },
    }).mount();
  });
</script>

{% schema %}
{
  "name": "Crispy Trustpilot",
  "class": "shopify-section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "trustpilot_title",
      "label": "Ratings Level",
      "default": "Excellent"
    },
    {
      "type": "text",
      "id": "trustpilot_text_mobile",
      "label": "Ratings Text Mobile",
      "default": "Rated <b>4.5</b> / 5 based on <b>3,181 reviews</b>. Showing our 5 star reviews."
    },
    {
      "type": "textarea",
      "id": "trustpilot_based_x_reviews",
      "label": "Total Reviews Text",
      "default": "Based on 2200+ reviews"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F8F8F8"
    },
    {
      "type": "range",
      "id": "slides_mobile",
      "label": "Slides per view",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 4,
      "info": "On mobile"
    },
    {
      "type": "range",
      "id": "slides_desktop",
      "label": "Slides per view",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 4,
      "info": "On desktop"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 32,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 32,
      "step": 4,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "liquid",
      "id": "trustpilot_max_width",
      "label": "Trustpilot Max Section Width",
      "default": "1440"
    }
  ],
  "blocks": [
    {
      "type": "stroopkoekje",
      "name": "Stroopkoekje",
      "settings": [
        {
          "type": "textarea",
          "id": "review_verified",
          "label": "Verified Text",
          "default": "Verified"
        },
        {
          "type": "textarea",
          "id": "review_title",
          "label": "Review Title",
          "default": "Respect naar die beertje"
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review Text",
          "default": "Mikey is echt een kanjer. Hij is zo cool, charmant, en echt sexy BEAST. Shoutout naar BEAST mike stroop"
        },
        {
          "type": "textarea",
          "id": "reviewer_name",
          "label": "Review Name",
          "default": "Mike Stroop 🤤"
        },
        {
          "type": "textarea",
          "id": "review_date",
          "label": "Review Date",
          "default": "5 dagen geleden"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Crispy Trustpilot"
    }
  ]
}
{% endschema %}
