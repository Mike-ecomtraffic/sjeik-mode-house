{% comment %} Reviews Slider Section {% endcomment %}

<section class="reviews-section" style="padding: {{ section.settings.section_padding_top }}px 20px {{ section.settings.section_padding_bottom }}px; background: {{ section.settings.background_color }};">
  {% if section.settings.section_title != blank %}
    <h2 class="reviews-heading" style="font-size: {{ section.settings.title_font_size }}px; color: {{ section.settings.title_color }};">{{ section.settings.section_title }}</h2>
  {% endif %}

  <div class="reviews-slider-wrapper">
    <div class="reviews-track" id="reviewsTrack-{{ section.id }}">
      {% for block in section.blocks %}
        <div class="review-card" data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          <div class="review-stars">
            {% assign star_count = block.settings.stars | default: 5 %}
            {% for i in (1..star_count) %}
              <span class="star" style="color: {{ section.settings.star_color }}; font-size: {{ section.settings.star_size }}px;">★</span>
            {% endfor %}
          </div>
          <p class="review-text" style="font-size: {{ section.settings.review_font_size }}px; color: {{ section.settings.review_text_color }};">{{ block.settings.review_text }}</p>
          <div class="review-author">
            <strong class="author-name" style="font-size: {{ section.settings.author_name_font_size }}px; color: {{ section.settings.author_name_color }};">{{ block.settings.author_name }}</strong>
            {% if block.settings.author_location != blank %}
              <span class="author-location" style="font-size: {{ section.settings.author_location_font_size }}px; color: {{ section.settings.author_location_color }};">{{ block.settings.author_location }}</span>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="reviews-dots" id="reviewsDots-{{ section.id }}">
      {% for block in section.blocks %}
        <button class="dot" data-index="{{ forloop.index0 }}" aria-label="Go to review {{ forloop.index }}"></button>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .reviews-section {
    font-family: var(--font-body-family), sans-serif;
    box-sizing: border-box;
    width: 100%;
  }

  .reviews-heading {
    text-align: center;
    font-weight: 700;
    margin: 0 0 40px 0;
    line-height: 1.3;
  }

  .reviews-slider-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    overflow: hidden;
    position: relative;
  }

  .reviews-track {
    display: flex;
    gap: 24px;
    transition: transform 0.45s cubic-bezier(0.4, 0, 0.2, 1);
    align-items: center;
    will-change: transform;
  }

  .review-card {
    background: transparent;
    border-radius: 6px;
    padding: 32px;
    min-width: calc(33.333% - 16px);
    flex-shrink: 0;
    box-sizing: border-box;
    opacity: 0.45;
    transform: scale(0.95);
    transition: opacity 0.45s ease, transform 0.45s ease, background 0.45s ease, box-shadow 0.45s ease;
  }

  .review-card--active {
    background: #ffffff;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.07);
    opacity: 1;
    transform: scale(1);
  }

  .review-stars {
    margin-bottom: 14px;
    line-height: 1;
  }

  .review-text {
    font-style: italic;
    line-height: 1.75;
    margin: 0 0 20px 0;
  }

  .author-name {
    display: block;
    font-weight: 700;
    margin-bottom: 3px;
  }

  .author-location {
    display: block;
  }

  .reviews-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 36px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #ccc;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.3s ease;
    flex-shrink: 0;
  }

  .dot--active {
    background: #111;
  }

  @media screen and (max-width: 749px) {
    .reviews-heading {
      font-size: calc({{ section.settings.title_font_size }}px * 0.8) !important;
      margin-bottom: 24px;
    }

    .review-card {
      min-width: calc(85vw);
      opacity: 1;
      transform: scale(1);
      background: #ffffff;
      box-shadow: 0 2px 20px rgba(0, 0, 0, 0.07);
      padding: 24px;
    }

    .reviews-track {
      gap: 16px;
    }

    .reviews-slider-wrapper {
      overflow: hidden;
    }
  }
</style>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const track = document.getElementById('reviewsTrack-' + sectionId);
  const dotsContainer = document.getElementById('reviewsDots-' + sectionId);

  if (!track || !dotsContainer) return;

  const cards = Array.from(track.querySelectorAll('.review-card'));
  const dots = Array.from(dotsContainer.querySelectorAll('.dot'));
  let current = 0;
  let autoplayTimer = null;

  function isMobile() {
    return window.innerWidth <= 749;
  }

  function getOffset(index) {
    if (cards.length === 0) return 0;

    if (isMobile()) {
      const cardWidth = cards[0].offsetWidth;
      const gap = 16;
      return index * (cardWidth + gap);
    } else {
      if (index === 0) return 0;
      const cardWidth = cards[0].offsetWidth;
      const gap = 24;
      return (index - 1) * (cardWidth + gap);
    }
  }

  function goTo(index) {
    current = (index + cards.length) % cards.length;

    cards.forEach((card, i) => {
      card.classList.toggle('review-card--active', i === current);
    });

    dots.forEach((dot, i) => {
      dot.classList.toggle('dot--active', i === current);
    });

    track.style.transform = 'translateX(-' + getOffset(current) + 'px)';
  }

  function startAutoplay() {
    stopAutoplay();
    autoplayTimer = setInterval(function() {
      goTo(current + 1);
    }, 5000);
  }

  function stopAutoplay() {
    if (autoplayTimer) {
      clearInterval(autoplayTimer);
      autoplayTimer = null;
    }
  }

  dots.forEach(function(dot, i) {
    dot.addEventListener('click', function() {
      stopAutoplay();
      goTo(i);
      startAutoplay();
    });
  });

  // Touch/swipe support
  let touchStartX = 0;
  let touchEndX = 0;

  track.addEventListener('touchstart', function(e) {
    touchStartX = e.changedTouches[0].screenX;
  }, { passive: true });

  track.addEventListener('touchend', function(e) {
    touchEndX = e.changedTouches[0].screenX;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > 40) {
      stopAutoplay();
      goTo(diff > 0 ? current + 1 : current - 1);
      startAutoplay();
    }
  }, { passive: true });

  window.addEventListener('resize', function() {
    track.style.transform = 'translateX(-' + getOffset(current) + 'px)';
  });

  goTo(0);
  startAutoplay();
})();
</script>

