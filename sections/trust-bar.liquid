{% comment %}
  Trust Bar Section — Icon + Heading + Text
  Desktop: 4 items in a row (stacked)
  Mobile: Swiper slider showing 1 at a time
  Fully customizable via theme editor blocks
{% endcomment %}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.css">

<style>
  .trust-bar {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.background_color }};
    {% if section.settings.show_top_border %}
      border-top: 1px solid {{ section.settings.border_color }};
    {% endif %}
    {% if section.settings.show_bottom_border %}
      border-bottom: 1px solid {{ section.settings.border_color }};
    {% endif %}
  }

  .trust-bar__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* Desktop: stacked grid */
  .trust-bar__grid {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
    gap: 32px;
  }

  .trust-bar__item {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .trust-bar__icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.icon_color }};
  }

  .trust-bar__icon svg {
    width: 100%;
    height: 100%;
  }

  .trust-bar__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .trust-bar__heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: {{ section.settings.heading_color }};
    margin: 0;
    line-height: 1.3;
  }

  .trust-bar__text {
    font-size: {{ section.settings.text_size }}px;
    line-height: 1.55;
    color: {{ section.settings.text_color }};
    margin: 0;
    max-width: 260px;
  }

  /* Mobile: hide grid, show swiper */
  .trust-bar__swiper-wrap {
    display: none;
  }

  @media (max-width: 767px) {
    .trust-bar__grid {
      display: none;
    }

    .trust-bar__swiper-wrap {
      display: block;
    }

    .trust-bar__container {
      padding: 0 24px;
    }

    .trust-bar__swiper-wrap .swiper {
      padding-bottom: 36px;
    }

    .trust-bar__swiper-wrap .swiper-pagination-bullet {
      width: 8px;
      height: 8px;
      background: #ccc;
      opacity: 1;
      transition: background 0.2s ease;
    }

    .trust-bar__swiper-wrap .swiper-pagination-bullet-active {
      background: #000;
    }
  }
</style>

<div class="trust-bar">
  <div class="trust-bar__container">

    {%- comment -%} Desktop: stacked grid {%- endcomment -%}
    <div class="trust-bar__grid">
      {% for block in section.blocks %}
        <div class="trust-bar__item" {{ block.shopify_attributes }}>
          {% if block.settings.custom_icon != blank %}
            <div class="trust-bar__icon">
              <img src="{{ block.settings.custom_icon | image_url: width: 120 }}" alt="{{ block.settings.heading }}" loading="lazy">
            </div>
          {% elsif block.settings.svg_icon != blank %}
            <div class="trust-bar__icon">
              {{ block.settings.svg_icon }}
            </div>
          {% else %}
            <div class="trust-bar__icon">
              {% case block.settings.icon_preset %}
                {% when 'shipping' %}
                  <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                    <path d="M42 20H52L60 32V48H54"/>
                    <path d="M42 48H24"/>
                    <path d="M18 48H4V12H42V48"/>
                    <circle cx="21" cy="50" r="4"/>
                    <circle cx="51" cy="50" r="4"/>
                    <path d="M42 26H56"/>
                  </svg>
                {% when 'returns' %}
                  <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                    <path d="M44 20H20V44H44V20Z"/>
                    <path d="M20 20L32 8L44 20"/>
                    <path d="M44 44L32 56L20 44"/>
                    <path d="M28 20V44"/>
                    <path d="M36 20V44"/>
                  </svg>
                {% when 'secure' %}
                  <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                    <path d="M32 4L8 16V32C8 46 18 55.6 32 60C46 55.6 56 46 56 32V16L32 4Z"/>
                    <path d="M22 34L28 40L42 26"/>
                  </svg>
                {% when 'service' %}
                  <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                    <rect x="6" y="14" width="52" height="36" rx="2"/>
                    <path d="M6 22L32 38L58 22"/>
                  </svg>
                {% else %}
                  <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
                    <circle cx="32" cy="32" r="24"/>
                    <path d="M32 20V32L40 40"/>
                  </svg>
              {% endcase %}
            </div>
          {% endif %}

          {% if block.settings.heading != blank %}
            <p class="trust-bar__heading">{{ block.settings.heading }}</p>
          {% endif %}

          {% if block.settings.text != blank %}
            <p class="trust-bar__text">{{ block.settings.text }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>

    {%- comment -%} Mobile: swiper slider {%- endcomment -%}
    <div class="trust-bar__swiper-wrap">
      <div class="swiper trust-bar-swiper">
        <div class="swiper-wrapper">
          {% for block in section.blocks %}
            <div class="swiper-slide">
              <div class="trust-bar__item" {{ block.shopify_attributes }}>
                {% if block.settings.custom_icon != blank %}
                  <div class="trust-bar__icon">
                    <img src="{{ block.settings.custom_icon | image_url: width: 120 }}" alt="{{ block.settings.heading }}" loading="lazy">
                  </div>
                {% elsif block.settings.svg_icon != blank %}
                  <div class="trust-bar__icon">
                    {{ block.settings.svg_icon }}
                  </div>
                {% else %}
                  <div class="trust-bar__icon">
                    {% case block.settings.icon_preset %}
                      {% when 'shipping' %}
                        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                          <path d="M42 20H52L60 32V48H54"/>
                          <path d="M42 48H24"/>
                          <path d="M18 48H4V12H42V48"/>
                          <circle cx="21" cy="50" r="4"/>
                          <circle cx="51" cy="50" r="4"/>
                          <path d="M42 26H56"/>
                        </svg>
                      {% when 'returns' %}
                        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                          <path d="M44 20H20V44H44V20Z"/>
                          <path d="M20 20L32 8L44 20"/>
                          <path d="M44 44L32 56L20 44"/>
                          <path d="M28 20V44"/>
                          <path d="M36 20V44"/>
                        </svg>
                      {% when 'secure' %}
                        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                          <path d="M32 4L8 16V32C8 46 18 55.6 32 60C46 55.6 56 46 56 32V16L32 4Z"/>
                          <path d="M22 34L28 40L42 26"/>
                        </svg>
                      {% when 'service' %}
                        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                          <rect x="6" y="14" width="52" height="36" rx="2"/>
                          <path d="M6 22L32 38L58 22"/>
                        </svg>
                      {% else %}
                        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="32" cy="32" r="24"/>
                          <path d="M32 20V32L40 40"/>
                        </svg>
                    {% endcase %}
                  </div>
                {% endif %}

                {% if block.settings.heading != blank %}
                  <p class="trust-bar__heading">{{ block.settings.heading }}</p>
                {% endif %}

                {% if block.settings.text != blank %}
                  <p class="trust-bar__text">{{ block.settings.text }}</p>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
        <div class="swiper-pagination"></div>
      </div>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/swiper@8/swiper-bundle.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (window.innerWidth < 768) {
      new Swiper('.trust-bar-swiper', {
        slidesPerView: 1,
        spaceBetween: 16,
        loop: true,
        autoplay: {
          delay: 3500,
          disableOnInteraction: false
        },
        pagination: {
          el: '.trust-bar__swiper-wrap .swiper-pagination',
          clickable: true
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Trust Bar",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#555555"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#e5e5e5"
    },
    {
      "type": "checkbox",
      "id": "show_top_border",
      "label": "Show Top Border",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_bottom_border",
      "label": "Show Bottom Border",
      "default": false
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon Size",
      "min": 24,
      "max": 80,
      "step": 4,
      "default": 48,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 10,
      "max": 20,
      "step": 1,
      "default": 13,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Body Font Size",
      "min": 10,
      "max": 16,
      "step": 1,
      "default": 12,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "default": 40,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust Item",
      "settings": [
        {
          "type": "select",
          "id": "icon_preset",
          "label": "Icon Preset",
          "options": [
            { "value": "shipping", "label": "Shipping Truck" },
            { "value": "returns", "label": "Returns Box" },
            { "value": "secure", "label": "Secure Shield" },
            { "value": "service", "label": "Customer Service" },
            { "value": "none", "label": "None (use custom)" }
          ],
          "default": "shipping",
          "info": "Choose a preset icon, or select 'None' and use custom SVG or image below"
        },
        {
          "type": "html",
          "id": "svg_icon",
          "label": "Custom SVG Icon",
          "info": "Paste custom SVG code here (overrides preset icon)"
        },
        {
          "type": "image_picker",
          "id": "custom_icon",
          "label": "Custom Image Icon",
          "info": "Upload an image icon (overrides preset and SVG)"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "FREE SHIPPING"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Enjoy free shipping on every order — fast, reliable, and with no hidden fees."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "category": "Custom",
      "blocks": [
        {
          "type": "trust_item",
          "settings": {
            "icon_preset": "shipping",
            "heading": "FREE SHIPPING",
            "text": "Enjoy free shipping on every order — fast, reliable, and with no hidden fees."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon_preset": "returns",
            "heading": "EASY RETURNS",
            "text": "Shop with confidence. If it's not the right fit, our hassle-free returns make it simple to send it back."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon_preset": "secure",
            "heading": "SECURE PAYMENT",
            "text": "Your security is our priority. Every payment is fully encrypted and 100% protected."
          }
        },
        {
          "type": "trust_item",
          "settings": {
            "icon_preset": "service",
            "heading": "CUSTOMER SERVICE",
            "text": "Real people, ready to help. Reach out anytime — we're here to make your experience effortless."
          }
        }
      ]
    }
  ]
}
{% endschema %}
