{% schema %}
{
  "name": "Collection Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "rgba(0, 0, 0, 0.5)"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Collection Title",
      "default": "Coco Gianna Bags"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Collection Description",
      "default": "<p>A breathable, naturally cooling sleep mask that increases relaxation and comfort to your eyes to fall asleep easily.</p>"
    },
    {
      "type": "text",
      "id": "trustpilot_text",
      "label": "Trustpilot Text",
      "default": "Excellent"
    },
    {
      "type": "image_picker",
      "id": "trustpilot_image",
      "label": "Trustpilot Image"
    }
  ],
  "presets": [
    {
      "name": "Collection Banner",
      "category": "Collection"
    }
  ]
}
{% endschema %}

<section class="crispy-collection-banner">
  <div class="crispy-collection-banner-image">
    <div class="crispy-image-overlay" style="background-color: {{ section.settings.overlay_color }};"></div>
    {% if section.settings.banner_image %}
      <img
        src="{{ section.settings.banner_image | img_url: '1500x' }}"
        loading="lazy"
        sizes="100vw"
        srcset="
          {{ section.settings.banner_image | img_url: '500x' }} 500w,
          {{ section.settings.banner_image | img_url: '800x' }} 800w,
          {{ section.settings.banner_image | img_url: '1080x' }} 1080w,
          {{ section.settings.banner_image | img_url: '1500x' }} 1500w
        "
        alt="{{ section.settings.title }}"
        class="crispy-banner-img"
      >
    {% endif %}
  </div>

  <div class="crispy-collection-banner-content-wrapper">
    <div class="crispy-collection-content">
      {% if section.settings.title != blank %}
        <h1 class="crispy-collection-title">{{ section.settings.title }}</h1>
      {% endif %}

      {% if section.settings.description != blank %}
        <p class="crispy-collection-paragraph">{{ section.settings.description }}</p>
      {% endif %}

      <div class="div-block">
        {% if section.settings.trustpilot_text != blank %}
          <p class="crispy-trustpilot">{{ section.settings.trustpilot_text }}</p>
        {% endif %}

        {% if section.settings.trustpilot_image != blank %}
          <img
            src="{{ section.settings.trustpilot_image | img_url: 'original' }}"
            loading="lazy"
            alt="Trustpilot"
          >
        {% endif %}
      </div>
    </div>
  </div>
</section>
