            "liquid": "<link href=\"https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;500&display=swap\" rel=\"stylesheet\">\n<style>\n  .stock-indicator {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    padding: 0;\n    margin-top: -0px;\n  }\n  .stock-dot {\n    width: 12px;\n    height: 12px;\n    background-color: #ff0000;\n    border-radius: 50%;\n    flex-shrink: 0;\n    position: relative;\n  }\n  .stock-dot::before {\n    content: '';\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    width: 12px;\n    height: 12px;\n    border-radius: 50%;\n    background-color: #ff0000;\n    animation: stock-pulse 1.8s ease-out infinite;\n  }\n  @keyframes stock-pulse {\n    0% { transform: translate(-50%, -50%) scale(1); opacity: 1; }\n    70% { transform: translate(-50%, -50%) scale(2); opacity: 0; }\n    100% { transform: translate(-50%, -50%) scale(1); opacity: 0; }\n  }\n  .stock-text {\n    font-family: 'Nunito Sans', sans-serif;\n    font-size: 16px;\n    font-weight: 500;\n    color: #333;\n  }\n  @media screen and (max-width: 749px) {\n    .stock-dot { width: 10px; height: 10px; }\n    .stock-text { font-size: 16px; }\n  }\n</style>\n<div class=\"stock-indicator\">\n  <span class=\"stock-dot\"></span>\n  <span class=\"stock-text\">Almost sold out, only a few left in stock!</span>\n</div>"
