    "faq_8iBrVL": {
      "type": "faq",
      "blocks": {
        "item_HaXHNc": {
          "type": "item",
          "settings": {
            "title": "Do you offer free shipping?",
            "content": "<p>Yes, we offer free shipping on all orders. We want to make sure your purchase arrives quickly and safely at no extra cost.</p>"
          }
        },
        "item_KPmxAW": {
          "type": "item",
          "settings": {
            "title": "Can I return an item if it doesn’t fit or if I don’t like it?",
            "content": "<p>Absolutely! You can return your order within 30 days of receiving it. Items must be unworn, undamaged, and in their original condition. Simply reach out to us through our Contact Page or email us directly at info@harperwells-boston.com, and we’ll guide you through the return process.<br/></p>"
          }
        },
        "item_NYpTag": {
          "type": "item",
          "settings": {
            "title": "How can I track my order?",
            "content": "<p>Once your order has been processed, you will receive a confirmation email with your personal tracking number. You can then track your package anytime through our Order Tracking Page.<br/><br/></p>"
          }
        },
        "item_bbdQPD": {
          "type": "item",
          "settings": {
            "title": "How do I choose the right size?",
            "content": "<p>Each product includes a detailed size chart to help you pick the best fit. If you’re between two sizes, we recommend going one size up for extra comfort. Still unsure? Our customer support team is happy to assist you.</p>"
          }
        },
        "item_T3x7HU": {
          "type": "item",
          "settings": {
            "title": "What payment methods do you accept?",
            "content": "<p>You can shop safely and securely with the following payment methods:</p><ul><li>Credit Cards (Visa & Mastercard)</li><li>Apple Pay</li><li>Google Pay</li><li>Shop Pay</li></ul>"
          }
        },
        "item_yagwFU": {
          "type": "item",
          "settings": {
            "title": "Is my payment secure?",
            "content": "<p>Yes, your payment is 100% secure. We use industry-standard SSL encryption to protect your information and ensure a safe checkout process.</p>"
          }
        },
        "item_cNqhrm": {
          "type": "item",
          "settings": {
            "title": "How long does shipping take?",
            "content": "<p>Orders are typically processed within <strong>1–3 business days</strong>. Delivery times may vary depending on your location and seasonal demand, but you will always receive tracking updates by email.</p>"
          }
        },
        "item_VUGXGh": {
          "type": "item",
          "settings": {
            "title": "How can I contact you if I have questions?",
            "content": "<p>Our customer support team is always happy to help. You can reach us through the Contact Page or by email at <strong>info@harperwells-boston.com</strong>. We usually reply within <strong>24 hours</strong>.</p>"
          }
        }
      },
