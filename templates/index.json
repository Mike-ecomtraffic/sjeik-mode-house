    "faq_fbCLwF": {
      "type": "faq",
      "blocks": {
        "item_BLJWXn": {
          "type": "item",
          "settings": {
            "title": "Do you offer free shipping?",
            "content": "<p>Yes, we offer free premium shipping because we value you as a customer and want to provide you with the best service.</p>"
          }
        },
        "item_Q8wdFK": {
          "type": "item",
          "settings": {
            "title": "Can I return the item(s) if I don’t like them?",
            "content": "<p>Yes, you can return your order within 30 days of receiving it.</p>"
          }
        },
        "item_d79M44": {
          "type": "item",
          "settings": {
            "title": "How can I track my order?",
            "content": "<p>You can track your order by entering your Order Number or Email/Phone Number on the \"Track Your Order\" page. Once you’ve entered your information and clicked \"Track,\" you will be able to see the status of your order.</p>"
          }
        },
        "item_PPGLpQ": {
          "type": "item",
          "settings": {
            "title": "Will I receive a confirmation email after placing an order?",
            "content": "<p>Yes, once you've placed your order, a confirmation will be sent to your email inbox. If you don’t see it, feel free to reach out to our customer service team, we’re happy to help you right away.<br/><br/>Email:<a>support@millermelbourne.com</a></p>"
          }
        },
        "item_RQ3iyj": {
          "type": "item",
          "settings": {
            "title": "What payment methods do you accept?",
            "content": "<p>You can pay safely and securely with the following payment methods: Credit Card, Visa, Mastercard, American Express, Apple Pay, Google Pay, Maestro, and Shop Pay.</p>"
          }
        }
      },
