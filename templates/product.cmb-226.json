            "liquid": "<style>\n    .stock-indicator {\n      display: flex;\n      align-items: center;\n      gap: 8px;\n      padding: 0;\n    }\n\n    .stock-dot {\n      width: 8px;\n      height: 8px;\n      background-color: #ff0000;\n      border-radius: 50%;\n      animation: flicker 1.5s infinite;\n      box-shadow: 0 0 8px rgba(255, 0, 0, 0.6);\n    }\n\n    @keyframes flicker {\n      0%, 100% {\n        opacity: 1;\n        box-shadow: 0 0 8px rgba(255, 0, 0, 0.6);\n      }\n      50% {\n        opacity: 0.3;\n        box-shadow: 0 0 4px rgba(255, 0, 0, 0.3);\n      }\n    }\n\n    .stock-text {\n      font-size: 14px;\n      color: #333;\n      font-weight: 500;\n      font-family: var(--font-body-family), var(--font-heading-family), sans-serif;\n    }\n\n    /* Mobile optimalisatie */\n    @media screen and (max-width: 749px) {\n      .stock-indicator {\n        gap: 6px;\n        padding: 0;\n      }\n\n      .stock-dot {\n        width: 7px;\n        height: 7px;\n      }\n\n      .stock-text {\n        font-size: 13px;\n      }\n    }\n\n    /* Desktop optimalisatie */\n    @media screen and (min-width: 750px) {\n      .stock-indicator {\n        gap: 10px;\n      }\n\n      .stock-dot {\n        width: 9px;\n        height: 9px;\n      }\n\n      .stock-text {\n        font-size: 15px;\n      }\n    }\n  </style>\n  <div class=\"stock-indicator\">\n    <span class=\"stock-dot\"></span>\n    <span class=\"stock-text\">Only 4 left in stock!</span>\n  </div>"
