        "liquid_BEDejD": {
          "type": "liquid",
          "disabled": true,
          "settings": {
            "liquid": "<!DOCTYPE html>\n<html lang=\"nl\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <style>\n    .shipping-bar {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 12px;\n      padding: 10px 16px;\n      width: 100%;\n      background-color: #f8f8f8;\n      border: 1px solid #e5e5e5;\n      border-radius: 6px;\n    }\n\n    .shipping-left {\n      display: flex;\n      align-items: center;\n      gap: 8px;\n      white-space: nowrap;\n    }\n\n    .shipping-dot {\n      width: 8px;\n      height: 8px;\n      background-color: #28a745;\n      border-radius: 50%;\n      animation: pulse 2s infinite;\n      flex-shrink: 0;\n      box-shadow: 0 0 6px rgba(40, 167, 69, 0.4);\n    }\n\n    @keyframes pulse {\n      0%, 100% {\n        opacity: 1;\n        box-shadow: 0 0 6px rgba(40, 167, 69, 0.4);\n      }\n      50% {\n        opacity: 0.5;\n        box-shadow: 0 0 3px rgba(40, 167, 69, 0.2);\n      }\n    }\n\n    .shipping-text {\n      font-size: 14px;\n      color: #333;\n      font-family: var(--font-body-family), var(--font-heading-family), sans-serif;\n    }\n\n    .shipping-text strong {\n      font-weight: 600;\n      color: #1a1a1a;\n    }\n\n    .shipping-right {\n      display: flex;\n      align-items: center;\n      gap: 6px;\n      white-space: nowrap;\n    }\n\n    .flag-emoji {\n      font-size: 20px;\n      line-height: 1;\n    }\n\n    .free-shipping-text {\n      font-size: 14px;\n      color: #1a1a1a;\n      font-weight: 700;\n      font-family: var(--font-body-family), var(--font-heading-family), sans-serif;\n    }\n\n    /* Mobile optimalisatie */\n    @media screen and (max-width: 749px) {\n      .shipping-bar {\n        gap: 10px;\n        padding: 8px 14px;\n      }\n\n      .shipping-left {\n        gap: 6px;\n      }\n\n      .shipping-dot {\n        width: 7px;\n        height: 7px;\n      }\n\n      .shipping-text {\n        font-size: 13px;\n      }\n\n      .flag-emoji {\n        font-size: 18px;\n      }\n\n      .free-shipping-text {\n        font-size: 13px;\n      }\n    }\n\n    /* Desktop optimalisatie */\n    @media screen and (min-width: 750px) {\n      .shipping-bar {\n        gap: 16px;\n        padding: 11px 18px;\n      }\n\n      .shipping-left {\n        gap: 10px;\n      }\n\n      .shipping-dot {\n        width: 9px;\n        height: 9px;\n      }\n\n      .shipping-text {\n        font-size: 15px;\n      }\n\n      .flag-emoji {\n        font-size: 22px;\n      }\n\n      .free-shipping-text {\n        font-size: 15px;\n      }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"shipping-bar\">\n    <div class=\"shipping-left\">\n      <span class=\"shipping-dot\"></span>\n      <span class=\"shipping-text\">Ships by <strong id=\"shipping-date\">Thu, Dec 18</strong></span>\n    </div>\n    <div class=\"shipping-right\">\n      <span class=\"flag-emoji\">🇦🇺</span>\n      <span class=\"free-shipping-text\">FREE Shipping</span>\n    </div>\n  </div>\n\n  <script>\n    // Bereken datum (vandaag + 2 dagen)\n    function getShippingDate() {\n      const today = new Date();\n      today.setDate(today.getDate() + 2);\n      \n      const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];\n      const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];\n      \n      const dayName = days[today.getDay()];\n      const monthName = months[today.getMonth()];\n      const date = today.getDate();\n      \n      return `${dayName}, ${monthName} ${date}`;\n    }\n    \n    // Update de datum op de pagina\n    document.getElementById('shipping-date').textContent = getShippingDate();\n  </script>\n</body>\n</html>"
